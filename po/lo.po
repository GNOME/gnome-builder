msgid "Builder"
msgstr "Builder"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:8
msgid "Create applications for GNOME"
msgstr "ສ້າງແອັບພລິເຄຊັນສຳລັບ GNOME"

#. developer_name tag deprecated with Appstream 1.0
#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:10
msgid "Christian Hergert"
msgstr "Christian Hergert"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:16
msgid ""
"Builder is an actively developed Integrated Development Environment for "
"GNOME. It combines integrated support for essential GNOME technologies such "
"as GTK+, GLib, and GNOME APIs with features that any developer will "
"appreciate, like syntax highlighting and snippets."
msgstr "Builder ເປັນສະພາບແວດລ້ອມການພັດທະນາແບບປະສົມປະສານ (IDE) ສຳລັບ GNOME ທີ່ກຳລັງພັດທະນາຢ່າງຕໍ່ເນື່ອງ. ມັນລວມການຮອງຮັບແບບປະສົມປະສານສຳລັບເທັກໂນໂລຢີທີ່ສຳຄັນຂອງ GNOME ເຊັ່ນ GTK+, GLib, ແລະ GNOME APIs ເຂົ້າກັບຄຸນສົມບັດທີ່ນັກພັດທະນາທຸກຄົນຈະຊື່ນຊອບ, ເຊັ່ນ ການເນັ້ນ syntax ແລະ snippets."

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:22
msgid ""
"You can rely on predictable releases of Builder with each new release of "
"GNOME every six months."
msgstr "ທ່ານສາມາດເຊື່ອໝັ້ນໃນການປ່ອຍເວີຊັນຂອງ Builder ທີ່ຄາດເດົາໄດ້ໃນທຸກໆການປ່ອຍເວີຊັນໃໝ່ຂອງ GNOME ທຸກໆຫົກເດືອນ."

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:26
msgid "Features:"
msgstr "ຄຸນສົມບັດ:"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:28
msgid "Built in syntax highlighting for many languages"
msgstr "ມີໂຕເນັ້ນ syntax ໃນໂຕສຳລັບຫຼາຍພາສາ"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:29
msgid "Side-by-side code editors"
msgstr "ໂຕແກ້ໄຂໂຄ້ດແບບຂ້າງຄຽງກັນ"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:30
msgid "Multi-monitor support"
msgstr "ຮອງຮັບຫຼາຍໜ້າຈໍ"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:31
msgid "Code overview mini-map"
msgstr "ແຜນທີ່ພາບລວມຂອງໂຄ້ດຂະໜາດນ້ອຍ"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:32
msgid "Integration with Git"
msgstr "ການເຊື່ອມໂຍງກັບ Git"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:33
msgid ""
"Integration with Autotools, Cargo, CMake, Gradle, Meson, Maven, Make, "
"PHPize, and Waf"
msgstr "ການເຊື່ອມໂຍງກັບ Autotools, Cargo, CMake, Gradle, Meson, Maven, Make, PHPize, ແລະ Waf"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:34
msgid "Clang based auto-completion, semantic highlighting, and diagnostics"
msgstr "ການຕື່ມໂຄ້ດອັດຕະໂນມັດ, ການເນັ້ນຄວາມໝາຍ, ແລະ ການວິນິດໄສ ໂດຍອີງໃສ່ Clang"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:35
msgid "Python based auto-completion, semantic highlighting, and diagnostics"
msgstr "ການຕື່ມໂຄ້ດອັດຕະໂນມັດ, ການເນັ້ນຄວາມໝາຍ, ແລະ ການວິນິດໄສ ໂດຍອີງໃສ່ Python"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:36
msgid "Vala based auto-completion and diagnostics"
msgstr "ການຕື່ມໂຄ້ດອັດຕະໂນມັດ ແລະ ການວິນິດໄສ ໂດຍອີງໃສ່ Vala"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:37
msgid "Auto indentation support for C, Python, Vala, and XML"
msgstr "ຮອງຮັບການຫຍໍ້ໜ້າອັດຕະໂນມັດສຳລັບ C, Python, Vala, ແລະ XML"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:38
msgid "HTML, Markdown, and reStructuredText, and Sphinx live preview"
msgstr "ສະແດງຕົວຢ່າງສົດສຳລັບ HTML, Markdown, reStructuredText, ແລະ Sphinx"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:39
msgid "Optional Vim, Emacs, and SublimeText style editing"
msgstr "ຮູບແບບການແກ້ໄຂແບບ Vim, Emacs, ແລະ SublimeText ທີ່ເປັນໂຕເລືອກ"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:40
msgid "An integrated software profiler for native applications"
msgstr "ໂຕວິເຄາະປະສິດທິພາບຊອບແວແບບປະສົມປະສານສຳລັບແອັບພລິເຄຊັນ native"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:41
msgid "An integrated debugger for native applications"
msgstr "ໂຕດີບັກແບບປະສົມປະສານສຳລັບແອັບພລິເຄຊັນ native"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:42
msgid "Support for building with jhbuild and flatpak runtimes"
msgstr "ຮອງຮັບການສ້າງດ້ວຍ jhbuild ແລະ flatpak runtimes"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:43
msgid "Support for viewing TODOs found within your code base"
msgstr "ຮອງຮັບການເບິ່ງ TODOs ທີ່ພົບໃນຖານໂຄ້ດຂອງທ່ານ"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:44
msgid "Fast fuzzy text search across files and symbols"
msgstr "ການຄົ້ນຫາຂໍ້ຄວາມແບບ fuzzy ທີ່ໄວໃນທົ່ວໄຟລ໌ ແລະ ສັນຍາລັກ"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:45
msgid "Arduino integration with arduino-cli"
msgstr "ການເຊື່ອມໂຍງ Arduino ກັບ arduino-cli"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:56
msgid "Debug with the GNU debugger"
msgstr "ດີບັກດ້ວຍໂຕດີບັກ GNU"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:60
msgid "Quickly access your projects"
msgstr "ເຂົ້າເຖິງໂປຣເຈັກຂອງທ່ານໄດ້ຢ່າງວ່ອງໄວ"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:64
msgid "Create new projects from a variety of templates"
msgstr "ສ້າງໂປຣເຈັກໃໝ່ຈາກແມ່ແບບທີ່ຫຼາກຫຼາຍ"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:68
msgid "Integration with Git to clone your projects"
msgstr "ການເຊື່ອມໂຍງກັບ Git ເພື່ອສຳເນົາໂປຣເຈັກຂອງທ່ານ"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:72
msgid "The source code editor"
msgstr "ໂຕແກ້ໄຂຊອດໂຄ້ດ"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:76
msgid "Fast global fuzzy search"
msgstr "ການຄົ້ນຫາແບບ fuzzy ທົ່ວໂລກທີ່ໄວ"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:80
msgid "Use the minimap to see more of the file"
msgstr "ໃຊ້ແຜນທີ່ຂະໜາດນ້ອຍເພື່ອເບິ່ງສ່ວນຕ່າງໆຂອງໄຟລ໌ໄດ້ຫຼາຍຂຶ້ນ"

#: data/gsettings/org.gnome.builder.build.gschema.xml:6
#: src/plugins/buildui/tweaks.ui:264
msgid "Build Parallelism"
msgstr "ການສ້າງແບບຂະໜານ"

#: data/gsettings/org.gnome.builder.build.gschema.xml:7
msgid ""
"Number of workers to use when performing builds. -1 for sensible default. 0 "
"for number of CPU."
msgstr "ຈຳນວນໂຕເຮັດວຽກທີ່ຈະໃຊ້ເມື່ອທຳການສ້າງ. -1 ສຳລັບຄ່າເລີ່ມຕົ້ນທີ່ເໝາະສົມ. 0 ສຳລັບຈຳນວນ CPU."

#: data/gsettings/org.gnome.builder.build.gschema.xml:11
msgid "Clear build logs"
msgstr "ລຶບບັນທຶກການສ້າງ"

#: data/gsettings/org.gnome.builder.build.gschema.xml:12
msgid "If enabled, build log pane will be cleared on rebuild."
msgstr "ຖ້າເປີດໃຊ້, ໜ້າຕ່າງບັນທຶກການສ້າງຈະຖືກລຶບເມື່ອສ້າງໃໝ່."

#: data/gsettings/org.gnome.builder.build.gschema.xml:16
msgid "Show Log When Building"
msgstr "ສະແດງບັນທຶກເມື່ອສ້າງ"

#: data/gsettings/org.gnome.builder.build.gschema.xml:17
msgid "If enabled, the build log will be raised when a build starts"
msgstr "ຖ້າເປີດໃຊ້, ບັນທຶກການສ້າງຈະຖືກສະແດງຂຶ້ນເມື່ອການສ້າງເລີ່ມຕົ້ນ"

#: data/gsettings/org.gnome.builder.build.gschema.xml:21
msgid "Allow network when metered"
msgstr "ອະນຸຍາດເຄືອຂ່າຍເມື່ອມີການຄິດຄ່າບໍລິການ"

#: data/gsettings/org.gnome.builder.build.gschema.xml:22
msgid ""
"Enable automated transfers upon building such as SDK downloads and "
"dependencies when connection is metered."
msgstr "ເປີດໃຊ້ການໂອນຍ້າຍອັດຕະໂນມັດເມື່ອສ້າງ ເຊັ່ນ ການດາວໂຫຼດ SDK ແລະ ໂຕອ້າງອີງ ເມື່ອການເຊື່ອມຕໍ່ມີການຄິດຄ່າບໍລິການ."

#: data/gsettings/org.gnome.builder.code-insight.gschema.xml.in:5
msgid "Ctags based autocompletion"
msgstr "ການຕື່ມໂຄ້ດອັດຕະໂນມັດໂດຍອີງໃສ່ Ctags"

#: data/gsettings/org.gnome.builder.code-insight.gschema.xml.in:6
msgid "Use Ctags for autocompletion."
msgstr "ໃຊ້ Ctags ສຳລັບການຕື່ມໂຄ້ດອັດຕະໂນມັດ."

#: data/gsettings/org.gnome.builder.code-insight.gschema.xml.in:10
msgid "Enable semantic highlighting"
msgstr "ເປີດໃຊ້ການເນັ້ນຄວາມໝາຍ"

#: data/gsettings/org.gnome.builder.code-insight.gschema.xml.in:11
msgid ""
"If enabled, additional highlighting will be provided in supported languages "
"based on information extracted from the source code."
msgstr "ຖ້າເປີດໃຊ້, ການເນັ້ນເພີ່ມເຕີມຈະຖືກສະໜອງໃຫ້ໃນພາສາທີ່ຮອງຮັບ ໂດຍອີງໃສ່ຂໍ້ມູນທີ່ສະກັດຈາກຊອດໂຄ້ດ."

#: data/gsettings/org.gnome.builder.code-insight.gschema.xml.in:15
msgid "Path to ctags executable"
msgstr "ເສັ້ນທາງໄປຫາໄຟລ໌ ctags"

#: data/gsettings/org.gnome.builder.code-insight.gschema.xml.in:16
msgid "The path to the ctags executable on the system."
msgstr "ເສັ້ນທາງໄປຫາໄຟລ໌ ctags ໃນລະບົບ."

#: data/gsettings/org.gnome.builder.debug.gschema.xml:5
msgid "Debugger Breakpoint at Main"
msgstr "ຈຸດຢຸດຂອງໂຕດີບັກທີ່ Main"

#: data/gsettings/org.gnome.builder.debug.gschema.xml:6
msgid "Debugger should automatically insert breakpoint at main() function."
msgstr "ໂຕດີບັກຄວນໃສ່ຈຸດຢຸດທີ່ຟັງຊັນ main() ໂດຍອັດຕະໂນມັດ."

#: data/gsettings/org.gnome.builder.debug.gschema.xml:10
msgid "Debugger Breakpoint at Criticals"
msgstr "ຈຸດຢຸດຂອງໂຕດີບັກທີ່ Criticals"

#: data/gsettings/org.gnome.builder.debug.gschema.xml:11
msgid ""
"Debugger should automatically insert breakpoint at g_critical() function."
msgstr "ໂຕດີບັກຄວນໃສ່ຈຸດຢຸດທີ່ຟັງຊັນ g_critical() ໂດຍອັດຕະໂນມັດ."

#: data/gsettings/org.gnome.builder.debug.gschema.xml:15
msgid "Debugger Breakpoint at Warnings and Criticals"
msgstr "ຈຸດຢຸດຂອງໂຕດີບັກທີ່ Warnings ແລະ Criticals"

#: data/gsettings/org.gnome.builder.debug.gschema.xml:16
msgid ""
"Debugger should automatically insert breakpoint at g_warning() and "
"g_critical function."
msgstr "ໂຕດີບັກຄວນໃສ່ຈຸດຢຸດທີ່ຟັງຊັນ g_warning() ແລະ g_critical ໂດຍອັດຕະໂນມັດ."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:19
msgid "Restore last position"
msgstr "ກູ້ຄືນຕຳແໜ່ງຫຼ້າສຸດ"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:20
msgid "Jump to the last position when reopening a file"
msgstr "ກະໂດດໄປທີ່ຕຳແໜ່ງຫຼ້າສຸດເມື່ອເປີດໄຟລ໌ຄືນ"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:24
msgid "Show modified lines"
msgstr "ສະແດງແຖວທີ່ແກ້ໄຂ"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:25
msgid ""
"If enabled, the editor will show line additions and changes next to the "
"source code."
msgstr "ຖ້າເປີດໃຊ້, ໂຕແກ້ໄຂຈະສະແດງການເພີ່ມ ແລະ ການປ່ຽນແປງແຖວຖັດຈາກຊອດໂຄ້ດ."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:29
msgid "Show diagnostics next to line number"
msgstr "ສະແດງການວິນິດໄສຖັດຈາກເລກແຖວ"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:30
msgid ""
"If enabled, the editor will show diagnostics to the left to the line numbers."
msgstr "ຖ້າເປີດໃຊ້, ໂຕແກ້ໄຂຈະສະແດງການວິນິດໄສຢູ່ເບື້ອງຊ້າຍຂອງເລກແຖວ."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:34
msgid "Highlight current line"
msgstr "ເນັ້ນແຖວປັດຈຸບັນ"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:35
msgid "If enabled, the editor will highlight the line containing the cursor."
msgstr "ຖ້າເປີດໃຊ້, ໂຕແກ້ໄຂຈະເນັ້ນແຖວທີ່ມີເຄີເຊີຢູ່."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:39
msgid "Highlight matching brackets"
msgstr "ເນັ້ນວົງເລັບທີ່ກົງກັນ"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:40
msgid "If enabled, the editor will highlight matching brackets."
