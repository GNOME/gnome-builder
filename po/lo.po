msgid "If enabled, the editor will show grid lines in the document."
msgstr "ຖ້າເປີດໃຊ້, ໂຕແກ້ໄຂຈະສະແດງເສັ້ນຕາຂ່າຍໃນເອກະສານ."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:80
msgid "If enabled, the editor will respect the font-name setting."
msgstr "ຖ້າເປີດໃຊ້, ໂຕແກ້ໄຂຈະເຄົາລົບການຕັ້ງຄ່າ font-name."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:84
msgid ""
"This setting is only respected if the use-custom-font setting is enabled."
msgstr "ການຕັ້ງຄ່ານີ້ຈະຖືກເຄົາລົບກໍຕໍ່ເມື່ອການຕັ້ງຄ່າ use-custom-font ຖືກເປີດໃຊ້."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:96
msgid "Overview Map Policy"
