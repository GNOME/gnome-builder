msgid ""
"If enabled, the project tree will sort directories before regular files."
msgstr "ຖ້າເປີດໃຊ້, ຕົ້ນໄມ້ໂປຣເຈັກຈະຈັດຮຽງໄດເຣັກທໍຣີກ່ອນໄຟລ໌ທຳມະດາ."

#: data/gsettings/org.gnome.builder.project.gschema.xml:7
msgid "Selected configuration for building"
msgstr "ການກຳໜົດຄ່າທີ່ເລືອກໄວ້ສຳລັບການສ້າງ"

#: data/gsettings/org.gnome.builder.project.gschema.xml:8
msgid ""
"The configuration that has been selected and will be restored the next time "
"the project loads."
msgstr "ການກຳໜົດຄ່າທີ່ຖືກເລືອກໄວ້ ແລະ ຈະຖືກກູ້ຄືນໃນຄັ້ງຕໍ່ໄປທີ່ໂປຣເຈັກໂຫຼດ."

#: data/gsettings/org.gnome.builder.project.gschema.xml:13
