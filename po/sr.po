#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:7 data/org.gnome.Builder.desktop.in.in:2 src/libide/editor/ide-editor-workspace.ui:50 src/libide/editor/ide-editor-workspace.ui:92 src/libide/gui/ide-application-actions.c:163 src/main.c:218
#: src/plugins/newcomers/gbp-newcomers-section.ui:39 src/plugins/shortcutui/tweaks.ui:25
msgid "Builder"
msgstr "Градитељ"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:8
msgid "Create applications for GNOME"
msgstr "Стварајте програме за Гном"

#. developer_name tag deprecated with Appstream 1.0
#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:10
msgid "Christian Hergert"
msgstr "Кристијан Хергерт"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:16
msgid ""
"Builder is an actively developed Integrated Development Environment for GNOME. It combines integrated support for essential GNOME technologies such as GTK+, GLib, and GNOME APIs with features that any developer will appreciate, like syntax highlighting and snippets."
msgstr "Градитељ је активно развијано интегрисано развојно окружење за Гном. Оно обједињује уграђену подршку за кључне Гномове технологије као што су ГТК+, Глиб и Гномове АПИ-је са могућностима које ће сваки програмер ценити, као што су истицање синтаксе и исечци кода."

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:22
msgid "You can rely on predictable releases of Builder with each new release of GNOME every six months."
msgstr "Можете се ослонити на предвидљива издања Градитеља уз свако ново издање Гнома на сваких шест месеци."

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:26
msgid "Features:"
msgstr "Могућности:"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:28
msgid "Built in syntax highlighting for many languages"
msgstr "Уграђено истицање синтаксе за многе језике"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:29
msgid "Side-by-side code editors"
msgstr "Упоредни уређивачи кода"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:30
msgid "Multi-monitor support"
msgstr "Подршка за више монитора"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:31
msgid "Code overview mini-map"
msgstr "Минијатурни преглед кода"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:32
msgid "Integration with Git"
msgstr "Интеграција са Гитом"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:33
msgid "Integration with Autotools, Cargo, CMake, Gradle, Meson, Maven, Make, PHPize, and Waf"
msgstr "Интеграција са алатима Autotools, Cargo, CMake, Gradle, Meson, Maven, Make, PHPize и Waf"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:34
msgid "Clang based auto-completion, semantic highlighting, and diagnostics"
msgstr "Самодовршавање, семантичко истицање и дијагностика засновани на Це-лангу"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:35
msgid "Python based auto-completion, semantic highlighting, and diagnostics"
msgstr "Самодовршавање, семантичко истицање и дијагностика засновани на Пајтону"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:36
msgid "Vala based auto-completion and diagnostics"
msgstr "Самодовршавање и дијагностика засновани на Вали"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:37
msgid "Auto indentation support for C, Python, Vala, and XML"
msgstr "Подршка за самостално увлачење за C, Пајтон, Валу и XML"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:38
msgid "HTML, Markdown, and reStructuredText, and Sphinx live preview"
msgstr "Живи преглед за HTML, Маркдаун, reStructuredText и Сфинкс"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:39
msgid "Optional Vim, Emacs, and SublimeText style editing"
msgstr "Опционално уређивање у стилу Вима, Емакса и Саблајм текста"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:40
msgid "An integrated software profiler for native applications"
msgstr "Интегрисани профилатор софтвера за изворне програме"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:41
msgid "An integrated debugger for native applications"
msgstr "Интегрисани исправљач грешака за изворне програме"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:42
msgid "Support for building with jhbuild and flatpak runtimes"
msgstr "Подршка за изградњу помоћу извршних окружења jhbuild и Flatpak"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:43
msgid "Support for viewing TODOs found within your code base"
msgstr "Подршка за преглед TODO-ова нађених у вашој бази кода"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:44
msgid "Fast fuzzy text search across files and symbols"
msgstr "Брза приближна претрага текста кроз датотеке и симболе"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:45
msgid "Arduino integration with arduino-cli"
msgstr "Интеграција Ардуина преко arduino-cli"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:110
msgid "Debug with the GNU debugger"
msgstr "Исправљање помоћу ГНУ исправљача грешака"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:114
msgid "Quickly access your projects"
msgstr "Брзо приступите вашим пројектима"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:118
msgid "Create new projects from a variety of templates"
msgstr "Направите нови пројекат помоћу великог броја шаблона"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:122
msgid "Integration with Git to clone your projects"
msgstr "Интеграција са Гитом ради клонирања ваших пројеката"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:126
msgid "The source code editor"
msgstr "Уређивач изворног кода"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:130
msgid "Fast global fuzzy search"
msgstr "Брза глобална приближна претрага"

#: data/appdata/org.gnome.Builder.metainfo.xml.in.in:134
msgid "Use the minimap to see more of the file"
msgstr "Користите мини-мапу за преглед већег дела датотеке"

#: data/gsettings/org.gnome.builder.build.gschema.xml:6 src/plugins/buildui/tweaks.ui:264
msgid "Build Parallelism"
msgstr "Упоредна изградња"

#: data/gsettings/org.gnome.builder.build.gschema.xml:7
msgid "Number of workers to use when performing builds. -1 for sensible default. 0 for number of CPU."
msgstr "Број радника које треба користити за изградњу. Вредност -1 је за разумну подразумевану вредност. 0 за број процесора."

#: data/gsettings/org.gnome.builder.build.gschema.xml:11
msgid "Clear build logs"
msgstr "Очисти дневнике изградње"

#: data/gsettings/org.gnome.builder.build.gschema.xml:12
msgid "If enabled, build log pane will be cleared on rebuild."
msgstr "Ако је омогућено, површ дневника изградње биће очишћена при поновној изградњи."

#: data/gsettings/org.gnome.builder.build.gschema.xml:16
msgid "Show Log When Building"
msgstr "Прикажи дневник при изградњи"

#: data/gsettings/org.gnome.builder.build.gschema.xml:17
msgid "If enabled, the build log will be raised when a build starts"
msgstr "Ако је омогућено, дневник изградње биће приказан када сама изградња започне"

#: data/gsettings/org.gnome.builder.build.gschema.xml:21
msgid "Allow network when metered"
msgstr "Допусти мрежу када је веза мерена"

#: data/gsettings/org.gnome.builder.build.gschema.xml:22
msgid "Enable automated transfers upon building such as SDK downloads and dependencies when connection is metered."
msgstr "Омогући самосталне преносе након изградње као што су СДК преузимања и зависности када је веза мерена."

#: data/gsettings/org.gnome.builder.code-insight.gschema.xml.in:5
msgid "Ctags based autocompletion"
msgstr "Самостално довршавање засновано на „ctags“-у"

#: data/gsettings/org.gnome.builder.code-insight.gschema.xml.in:6
msgid "Use Ctags for autocompletion."
msgstr "Користи „ctags“ за самостално довршавање."

#: data/gsettings/org.gnome.builder.code-insight.gschema.xml.in:10
msgid "Enable semantic highlighting"
msgstr "Омогући семантичко истицање"

#: data/gsettings/org.gnome.builder.code-insight.gschema.xml.in:11
msgid "If enabled, additional highlighting will be provided in supported languages based on information extracted from the source code."
msgstr "Ако је омогућено, додатно истицање ће бити обезбеђено у подржаним језицима на основу података извучених из изворног кода."

#: data/gsettings/org.gnome.builder.code-insight.gschema.xml.in:15
msgid "Path to ctags executable"
msgstr "Путања до „ctags“ извршне датотеке"

#: data/gsettings/org.gnome.builder.code-insight.gschema.xml.in:16
msgid "The path to the ctags executable on the system."
msgstr "Путања до „ctags“ извршне датотеке на систему."

#: data/gsettings/org.gnome.builder.debug.gschema.xml:5
msgid "Debugger Breakpoint at Main"
msgstr "Исправљач грешака: тачка прекида на главној функцији"

#: data/gsettings/org.gnome.builder.debug.gschema.xml:6
msgid "Debugger should automatically insert breakpoint at main() function."
msgstr "Исправљач грешака треба самостално да уметне тачку прекида у функцији main()."

#: data/gsettings/org.gnome.builder.debug.gschema.xml:10
msgid "Debugger Breakpoint at Criticals"
msgstr "Исправљач грешака: тачка прекида на критичним грешкама"

#: data/gsettings/org.gnome.builder.debug.gschema.xml:11
msgid "Debugger should automatically insert breakpoint at g_critical() function."
msgstr "Исправљач грешака треба самостално да уметне тачку прекида у функцији g_critical()."

#: data/gsettings/org.gnome.builder.debug.gschema.xml:15
msgid "Debugger Breakpoint at Warnings and Criticals"
msgstr "Исправљач грешака: тачка прекида на упозорењима и критичним грешкама"

#: data/gsettings/org.gnome.builder.debug.gschema.xml:16
msgid "Debugger should automatically insert breakpoint at g_warning() and g_critical function."
msgstr "Исправљач грешака треба самостално да уметне тачку прекида у функцијама g_warning() и g_critical()."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:19
msgid "Restore last position"
msgstr "Поврати последњи положај"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:20
msgid "Jump to the last position when reopening a file"
msgstr "Скочи на последњи положај приликом поновног отварања датотеке"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:24
msgid "Show modified lines"
msgstr "Прикажи измењене редове"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:25
msgid "If enabled, the editor will show line additions and changes next to the source code."
msgstr "Ако је омогућено, уређивач ће приказивати додавања и измене редова поред изворног кода."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:29
msgid "Show diagnostics next to line number"
msgstr "Прикажи дијагностику поред броја реда"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:30
msgid "If enabled, the editor will show diagnostics to the left to the line numbers."
msgstr "Ако је омогућено, уређивач ће приказивати дијагностику лево од бројева редова."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:34
msgid "Highlight current line"
msgstr "Истакни тренутни ред"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:35
msgid "If enabled, the editor will highlight the line containing the cursor."
msgstr "Ако је омогућено, уређивач ће истаћи ред у коме се налази курсор."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:39
msgid "Highlight matching brackets"
msgstr "Истакни упарене заграде"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:40
msgid "If enabled, the editor will highlight matching brackets."
msgstr "Ако је омогућено, уређивач ће истаћи упарене заграде."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:44
msgid "Show line numbers"
msgstr "Прикажи бројеве редова"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:45
msgid "If enabled, the editor will show line numbers."
msgstr "Ако је омогућено, уређивач ће приказивати бројеве редова."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:49
msgid "Show relative line numbers"
msgstr "Прикажи релативне бројеве редова"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:50
msgid "If enabled, the editor will show relative line numbers."
msgstr "Ако је омогућено, уређивач ће приказивати релативне бројеве редова."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:54
msgid "Use line selection styling"
msgstr "Користи стилизовање избора реда"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:55
msgid "If enabled, the editor will use selected style for line numbers for whole lines selected."
msgstr "Ако је омогућено, уређивач ће користити изабрани стил за бројеве редова када су цели редови изабрани."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:59 src/plugins/editorui/tweaks.ui:500
msgid "Smart Backspace"
msgstr "Паметно брисање уназад"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:60
msgid "Backspace will remove additional spaces to keep you aligned to the indentation size."
msgstr "Тастер за брисање уназад ће уклонити додатне размаке како бисте остали поравнати са величином увлачења."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:70 src/plugins/editorui/tweaks.ui:512
msgid "Smart Home/End"
msgstr "Паметни тастери „Home/End“"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:71
msgid "Modifies the behavior of Home/End keys."
msgstr "Мења понашање Home/End тастера."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:75
msgid "Show grid lines"
msgstr "Прикажи линије мреже"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:76
msgid "If enabled, the editor will show grid lines in the document."
msgstr "Ако је омогућено, уређивач ће приказивати линије мреже у документу."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:80
msgid "If enabled, the editor will respect the font-name setting."
msgstr "Ако је омогућено, уређивач ће поштовати подешавање назива фонта."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:84
msgid "This setting is only respected if the use-custom-font setting is enabled."
msgstr "Ово подешавање се поштује само ако је омогућено подешавање за коришћење произвољног фонта."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:96
msgid "Overview Map Policy"
msgstr "Смерница мапе прегледа"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:97
msgid "When the overview map should be displayed."
msgstr "Када треба приказати мапу прегледа."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:101 src/plugins/editorui/tweaks.ui:283
msgid "Draw Spaces"
msgstr "Исцртај размаке"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:102
msgid "The various types of space to draw in the editor."
msgstr "Разне врсте размака које ће уређивач исцртати."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:111 src/plugins/editorui/tweaks.ui:82
msgid "Wrap Text"
msgstr "Преломи текст"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:112
msgid "The way to wrap a long line of text for a better visibility."
msgstr "Начин преламања дугачког реда текста ради боље видљивости."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:116
msgid "Autosave Enabled"
msgstr "Аутоматско чување је омогућено"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:117
msgid "Enable or disable autosave feature."
msgstr "Омогућите или онемогућите могућност аутоматског чувања."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:122
msgid "Autosave Frequency"
msgstr "Учесталост аутоматског чувања"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:123
msgid "The number of seconds after modification before auto saving."
msgstr "Број секунди након измене пре аутоматског чувања."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:128
msgid "Completion Row Count"
msgstr "Број редова за довршавање"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:129
msgid "The number of completion rows to display to the user."
msgstr "Број редова за довршавање које треба приказати кориснику."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:134 src/plugins/editorui/tweaks.ui:65
msgid "Line Height"
msgstr "Висина реда"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:135
msgid "The line height to use for the selected font."
msgstr "Висина реда која ће се користити за изабрани фонт."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:139
msgid "Interactive Completion"
msgstr "Интерактивно довршавање"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:140
msgid "If enabled, Builder will automatically display completion proposals as you type."
msgstr "Ако је омогућено, Градитељ ће самостално приказивати предлоге за довршавање током куцања."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:145
msgid "Minimum characters for matching selection."
msgstr "Најмањи број знакова за подударни избор."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:146
msgid "Specify the minimum number of characters for selection matching."
msgstr "Наведите најмањи број знакова за подударање избора."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:150
msgid "Enable Snippets"
msgstr "Омогући исечке"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:151
msgid "Allow expanding snippets from the editor by pressing tab after the snippet trigger."
msgstr "Допусти ширење исечака из уређивача притиском на тастер табулатора након окидача исечка."

#: data/gsettings/org.gnome.builder.editor.gschema.xml:155
msgid "Select First Completion"
msgstr "Изабери прво довршавање"

#: data/gsettings/org.gnome.builder.editor.gschema.xml:156
msgid "Automatically select the first auto-completion entry."
msgstr "Самостално изабери прву ставку самодовршавања."

#: data/gsettings/org.gnome.builder.editor.language.gschema.xml:42
msgid "Spaces Style"
msgstr "Стил размака"

#: data/gsettings/org.gnome.builder.editor.language.gschema.xml:43
msgid "How to apply spaces when reformatting text."
msgstr "Начин примене размака при поновном форматирању текста."

#: data/gsettings/org.gnome.builder.extension-type.gschema.xml:5
msgid "Enabled"
msgstr "Омогућено"

#: data/gsettings/org.gnome.builder.extension-type.gschema.xml:6
msgid "If the type within the extension is enabled."
msgstr "Да ли је врста унутар проширења омогућена."

#: data/gsettings/org.gnome.builder.gschema.xml:5
msgid "Window size"
msgstr "Величина прозора"

#: data/gsettings/org.gnome.builder.gschema.xml:6
msgid "Window size (width and height)."
msgstr "Величина прозора (ширина и висина)."

#: data/gsettings/org.gnome.builder.gschema.xml:10
msgid "Window maximized"
msgstr "Увећан прозор"

#: data/gsettings/org.gnome.builder.gschema.xml:11
msgid "Window maximized state"
